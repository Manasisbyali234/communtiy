# App
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/community_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=<min_32_char_secret>
JWT_REFRESH_SECRET=<min_32_char_secret>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# OTP
OTP_EXPIRY_MINUTES=10

# OAuth — Google
GOOGLE_CLIENT_ID=<google_client_id>
GOOGLE_CLIENT_SECRET=<google_client_secret>

# OAuth — Apple
APPLE_CLIENT_ID=<bundle_id>
APPLE_TEAM_ID=<team_id>
APPLE_KEY_ID=<key_id>
APPLE_PRIVATE_KEY=<private_key>

# AWS S3
STORAGE_REGION=<region>
STORAGE_ACCESS_KEY=<aws_access_key>
STORAGE_SECRET_KEY=<aws_secret_key>
STORAGE_BUCKET=<bucket_name>
STORAGE_PUBLIC_URL=<bucket_public_url>

# Email (SMTP)
SMTP_HOST=<smtp_host>
SMTP_PORT=587
SMTP_USER=<smtp_user>
SMTP_PASS=<smtp_password>
EMAIL_FROM=<from_email>

# Expo Push Notifications
EXPO_ACCESS_TOKEN=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Swagger
SWAGGER_ENABLED=true
